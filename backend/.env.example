# ============================================================================
# FLASK CONFIGURATION
# ============================================================================

FLASK_PORT=5000
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here

# ============================================================================
# OLLAMA CONFIGURATION (Chat API)
# ============================================================================

# Make sure Ollama is running: ollama serve
OLLAMA_API_URL=http://localhost:11434

# Model name (must be installed: ollama pull llama3)
OLLAMA_MODEL=llama3

# Request timeout in seconds
OLLAMA_TIMEOUT=30

# ============================================================================
# LLM PARAMETERS - Tuned for Health Assistant Responses
# ============================================================================

# Temperature: Controls response creativity (0.0-1.0)
# 0.9 = balanced between consistent and creative advice
OLLAMA_TEMPERATURE=0.9

# Top-p: Nucleus sampling - only use top 90% probable tokens
OLLAMA_TOP_P=0.9

# Repeat penalty: Penalizes repetitive content (1.2 = good for health advice)
OLLAMA_REPEAT_PENALTY=1.2

# ============================================================================
# LEGACY LLM CONFIGURATION (Still used by main app.py)
# ============================================================================

LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=80
LLM_RESPONSE_TIMEOUT=40
LLM_NUM_PREDICT=70
LOG_LEVEL=INFO

# ============================================================================
# DATABASE
# ============================================================================

DATABASE_URL=sqlite:///health_assistant.db

# ============================================================================
# QUICK START
# ============================================================================

# 1. Install Ollama from https://ollama.ai
# 2. Pull the model: ollama pull llama3
# 3. Start Ollama: ollama serve
# 4. Install dependencies: pip install -r requirements.txt
# 5. Run the chat API: python chat_app.py
# 6. Test the API: python test_chat_api.py
