# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DATABASE_URL=sqlite:///health_assistant.db
# For production, use: postgresql://user:password@localhost:5432/health_db

# CORS Configuration
CORS_ORIGINS=http://localhost:5174,https://yourdomain.com

# OpenAI Configuration (for chat feature)
OPENAI_API_KEY=your-openai-api-key-here

# Tesseract Configuration (for OCR)
TESSERACT_PATH=/usr/bin/tesseract

# Server Configuration
HOST=0.0.0.0
PORT=5000

# Frontend URL
FRONTEND_URL=http://localhost:5174
