# AI Health Assistant - Frontend Environment Variables

# API Configuration
# Point to your Flask backend API
VITE_API_URL=http://localhost:5000

# App Configuration
VITE_APP_NAME=AI Health Assistant
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_CHAT=true
VITE_ENABLE_SYMPTOM_ANALYSIS=true
VITE_ENABLE_MEDICINE_VERIFICATION=true

# Debug
VITE_DEBUG=false

# Note: VITE_ prefix makes these variables accessible in the frontend
# Access them using: import.meta.env.VITE_API_URL
